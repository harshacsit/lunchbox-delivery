<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP COLOUR STRIP -->
        <View
            android:id="@+id/vStatusStrip"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="#E65100"/>

        <!-- MAIN CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Order number circle -->
            <LinearLayout
                android:layout_width="46dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="top|center_horizontal"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvOrderNum"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/circle_orange"/>

                <TextView
                    android:id="@+id/dragHandle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⠿"
                    android:textSize="20sp"
                    android:textColor="#CCCCCC"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Customer info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Name + status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvCustomerName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Customer Name"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#E65100"
                        android:background="#FFF3E0"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"/>
                </LinearLayout>

                <!-- Phone tap to call -->
                <LinearLayout
                    android:id="@+id/phoneRow"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                        android:text="📞" android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9876543210"
                        android:textSize="14sp"
                        android:textColor="#1565C0"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Pickup location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                        android:text="📦" android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvPickup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pickup"
                        android:textSize="13sp"
                        android:textColor="#424242"/>
                </LinearLayout>

                <!-- Delivery address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                        android:text="📍" android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Address"
                        android:textSize="13sp"
                        android:textColor="#424242"/>
                </LinearLayout>

                <!-- Item count pill -->
                <TextView
                    android:id="@+id/tvItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 item"
                    android:textSize="11sp"
                    android:textColor="#5D4037"
                    android:background="#FBE9E7"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- NOTES ROW -->
        <LinearLayout
            android:id="@+id/notesRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFDE7"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                android:text="📝" android:textSize="13sp"/>
            <TextView
                android:id="@+id/tvNotes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="#5D4037"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F0F0F0"/>

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Picked + Delayed (shown when Pending or Delayed) -->
            <LinearLayout
                android:id="@+id/rowActionMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPicked"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="✓ Picked Up"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#2E7D32"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelayed"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="⚠ Delayed"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#C62828"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <!-- Delivered Button (shown ONLY after Picked) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelivered"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✓ Mark as Delivered"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1565C0"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Call Admin (shown ONLY after Picked) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallAdmin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📞 Call Admin"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#E65100"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Call Customer (always visible) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCall"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📞 Call Customer"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                app:backgroundTint="#E3F2FD"
                app:cornerRadius="12dp"
                app:strokeColor="#BBDEFB"
                app:strokeWidth="1dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>