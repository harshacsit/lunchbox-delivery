<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── NOTIFICATIONS SECTION ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOTIFICATIONS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.12"
            android:paddingStart="4dp"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="4dp">

                <!-- New delivery notification toggle -->
                <LinearLayout android:id="@+id/rowNewDelivery"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔔" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="New delivery assigned"
                        android:textSize="14sp" android:textColor="#212121"/>
                    <Switch android:id="@+id/switchNewDelivery"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <!-- Delay reminder toggle -->
                <LinearLayout android:id="@+id/rowDelayReminder"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚠️" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Delay reminders"
                        android:textSize="14sp" android:textColor="#212121"/>
                    <Switch android:id="@+id/switchDelayReminder"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SECURITY SECTION ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECURITY"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.12"
            android:paddingStart="4dp"
            android:layout_marginBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="4dp">

                <!-- Reset MPIN — NEW -->
                <LinearLayout android:id="@+id/itemResetMpin"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔐" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reset MPIN"
                            android:textSize="14sp" android:textColor="#212121"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Change your 4-digit app PIN"
                            android:textSize="11sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="#BDBDBD"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <!-- Change password -->
                <LinearLayout android:id="@+id/itemChangePassword"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Change password"
                        android:textSize="14sp" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="#BDBDBD"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── ACCOUNT SECTION ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.12"
            android:paddingStart="4dp"
            android:layout_marginBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="4dp">

                <!-- Update phone -->
                <LinearLayout android:id="@+id/itemUpdatePhone"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📞" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Update phone number"
                        android:textSize="14sp" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="#BDBDBD"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <!-- Update vehicle -->
                <LinearLayout android:id="@+id/itemUpdateVehicle"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🚗" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Update vehicle info"
                        android:textSize="14sp" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="#BDBDBD"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── APP VERSION ── -->
        <TextView android:id="@+id/tvAppVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lunchbox Delivery"
            android:textSize="11sp"
            android:textColor="#BDBDBD"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"/>

        <!-- ── SIGN OUT ── -->
        <LinearLayout android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#FFEBEE"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#C62828"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

    </LinearLayout>
</ScrollView>
