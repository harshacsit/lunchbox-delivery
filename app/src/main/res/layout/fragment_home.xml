<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/fragment_home.xml
    Replace your existing fragment_home.xml with this.

    CHANGES FROM PREVIOUS VERSION:
    - Removed @color/chip_bg_selector from chips (causes crash if color/ folder missing)
    - Chip styling done in Java instead (safer for beginners)
    - emptyState is now LinearLayout correctly typed
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FA">

    <!-- FILTER CHIPS BAR -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="6dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="All"
                android:textSize="13sp"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPending"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Pending"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPicked"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Picked"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDelayed"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Delayed"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDelivered"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Delivered"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- COUNT LINE -->
    <TextView
        android:id="@+id/tvFilterCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"/>

    <!-- DELIVERY LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"/>

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="52sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All done!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvEmptySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No deliveries here"
            android:textSize="14sp"
            android:textColor="#9E9E9E"/>

    </LinearLayout>

</LinearLayout>